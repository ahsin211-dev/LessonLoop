# etl-api local development environment
# Copy to .env and adjust as needed

# DynamoDB
TABLE_NAME=LessonLoop-local
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Auth (dev)
JWT_SECRET=lessonloop-dev-secret-change-in-production
AUTH_DEV_MODE=true

# Cognito SSO (production — leave blank for local dev)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# AI services (stubs enabled by default for local dev)
BEDROCK_STUB=true
OPENSEARCH_STUB=true
OPENSEARCH_ENDPOINT=
OPENSEARCH_RBIS_INDEX=rbis-strategies
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
